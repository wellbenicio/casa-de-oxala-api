# Casa de Oxalá API — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env or any file with real secrets.

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# Local: docker compose up -d  (see docker-compose.yml)
# Azure: jdbc:postgresql://<server>.postgres.database.azure.com:5432/<db>?sslmode=require
# ---------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/casadeoxala
SPRING_DATASOURCE_USERNAME=casadeoxala
SPRING_DATASOURCE_PASSWORD=casadeoxala

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-at-least-32-characters-here
JWT_EXPIRATION_MS=86400000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Active Spring Profile
# ---------------------------------------------------------------------------
# local (no suffix) — for local development
# dev   — Azure dev Container App
# prod  — Azure prod Container App (set via Container Apps env var, not here)
SPRING_PROFILES_ACTIVE=
