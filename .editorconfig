# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java
[*.java]
indent_style = space
indent_size = 4

# XML (Maven POM, Spring config)
[*.xml]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Properties
[*.properties]
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (line breaks)
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2
